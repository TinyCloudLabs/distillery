# agent.env.example — template for the Phala CVM secret env file.
#
# Copy to agent.env, fill the real values, and pass it to the deploy:
#   phala deploy -c harness/agent/docker-compose.yml -n distillery-agent \
#     -e harness/agent/agent.env -t tdx.small
#
# Phala encrypts this file CLIENT-SIDE before transmission — the values never
# land in the plaintext compose. agent.env itself is gitignored (NEVER commit
# real secrets). Only this .example is committed.

# Per-install bearer token the feed sends on POST /agent/delegation + /agent/run.
# Generate one: openssl rand -base64 32
AGENT_API_TOKEN=

# Claude auth for the headless generate step (NO macOS Keychain in the TEE).
# Provide EXACTLY ONE of these:
ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=

# Trusted browser origin(s) the agent reflects for CORS (comma-separated, no
# wildcard). Set to the deployed feed origin(s), e.g.
#   https://tinyfeed.pages.dev,https://tinyfeed.tinycloud.xyz
AGENT_ALLOWED_ORIGIN=

# The image to run (registry tag the CVM pulls). Override the compose default.
# AGENT_IMAGE=ghcr.io/tinycloudlabs/distillery-agent:<sha>

# Pull creds for a PRIVATE GHCR image (omit if the package is public). The CVM
# pulls at boot, so a private package needs these. DSTACK_DOCKER_REGISTRY is
# REQUIRED for GHCR — the dstack pre-launch login defaults to docker.io and the
# pull fails "unauthorized" without it (verified). Password = a token with
# read:packages.
# DSTACK_DOCKER_REGISTRY=ghcr.io
# DSTACK_DOCKER_USERNAME=
# DSTACK_DOCKER_PASSWORD=

# --- optional -----------------------------------------------------------------
# Illustrated-hero key for write-article (any one works; first present wins).
# GOOGLE_AI_API_KEY=
# Generation model for `claude -p` (default opus).
# AGENT_GEN_MODEL=opus
# Override the TinyCloud node / chain (defaults: node.tinycloud.xyz, chain 1).
# TINYCLOUD_HOST=https://node.tinycloud.xyz
# AGENT_CHAIN_ID=1
# AGENT_NAME=Distillery Agent
# AGENT_TRANSCRIPT_COUNT=5
