# feedrun.env — machine-specific config for ops/launchd/feedrun.sh
# (spec §7a / §10 R5). Copy to feedrun.env and fill in. feedrun.env is
# GITIGNORED — it carries absolute tool paths + the transcript-dir allowlist.
#
#   cp ops/launchd/feedrun.env.example ops/launchd/feedrun.env
#   # then edit the values below
#
# WHY THIS FILE EXISTS: launchd starts jobs with a MINIMAL environment — no
# login PATH, no shell rc. The wrapper sources this file to rebuild PATH so
# `claude` and `bun` resolve, and to learn where the corpus lives.

# --- PATH (REQUIRED) ----------------------------------------------------------
# Must include the dirs holding `claude` and `bun`. Resolve the real locations
# on THIS machine with:  dirname "$(command -v claude)" ; dirname "$(command -v bun)"
# On Hunter's machine: claude → /opt/homebrew/bin, bun → ~/.bun/bin.
export PATH="/opt/homebrew/bin:$HOME/.bun/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# --- TRANSCRIPT_DIRS (REQUIRED for a full run) --------------------------------
# Comma-separated ABSOLUTE corpus dirs. index-corpus reads this; nothing is
# hardcoded in any skill. On Hunter's machine, the three real vault folders:
export TRANSCRIPT_DIRS="/Users/hunterhorsfall/Obsidian Vaults/TinyCloud 2025/Team Relays/TinyCloud Team Space/Fireflies-Transcripts,/Users/hunterhorsfall/Obsidian Vaults/TinyCloud 2025/Team Relays/TinyCloud Team Space/Gemini-Transcripts,/Users/hunterhorsfall/Obsidian Vaults/TinyCloud 2025/Team Relays/TinyCloud Team Space/Soundcore-Transcripts"

# --- optional run knobs -------------------------------------------------------
# export FEEDRUN_MODE=daily        # daily (default) | backfill
# export FEEDRUN_MODEL=opus        # generation model for the headless agent
# export FEEDRUN_SINCE=14d         # recency lower bound (relative or YYYY-MM-DD);
#                                  #   unset = recipe default (last run, else 7d)
#
# The Gemini key (GOOGLE_AI_API_KEY / GEMINI_API_KEY / GOOGLE_API_KEY) is NOT set
# here — the wrapper sources it from the repo .env (also gitignored).
