# server.env — config for the keep-alive feed server (spec §7b).
# Copy to server.env and fill in. server.env is GITIGNORED.
#
#   cp ops/launchd/server.env.example ops/launchd/server.env
#
# The server plist (com.tinycloud.distillery.server.plist) sources this so the
# OpenKey front-door allowlist + paths survive a reboot.

# --- PATH (REQUIRED) ----------------------------------------------------------
# launchd's minimal PATH won't find bun. Same as feedrun.env.
export PATH="/opt/homebrew/bin:$HOME/.bun/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# --- OpenKey front-door allowlist (REQUIRED) ----------------------------------
# Comma-separated OpenKey addresses allowed to sign in. Empty = nobody can sign
# in (the server logs a warning). This gates /api/* and /media/* — including
# POST /api/generate (the highest-privilege route: it spends money + publishes).
export OPENKEY_ALLOWED_ADDRESSES="0xYOUR_OPENKEY_ADDRESS_HERE"

# --- the spawned feed-run needs these too (POST /api/generate inherits server env) ---
# The Generate button spawns ops/launchd/feedrun.sh, which sources feedrun.env +
# the repo .env on its own — so these are belt-and-suspenders for a full run
# triggered from the button. Set them if you want the button to work even with a
# bare feedrun.env.
export TRANSCRIPT_DIRS="/Users/hunterhorsfall/Obsidian Vaults/TinyCloud 2025/Team Relays/TinyCloud Team Space/Fireflies-Transcripts,/Users/hunterhorsfall/Obsidian Vaults/TinyCloud 2025/Team Relays/TinyCloud Team Space/Gemini-Transcripts,/Users/hunterhorsfall/Obsidian Vaults/TinyCloud 2025/Team Relays/TinyCloud Team Space/Soundcore-Transcripts"
# export GOOGLE_AI_API_KEY=...     # or source it from the repo .env

# --- optional server knobs ----------------------------------------------------
# export PORT=4242                 # the tunnel config points at localhost:4242
# export HOST=127.0.0.1            # loopback only (the tunnel connects locally)
# export ARTIFACTS_DIR=../artifacts
# export AUTH_DISABLED=1           # NEVER in production — local HTTP dev only
