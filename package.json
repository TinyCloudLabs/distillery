{
  "name": "distillery",
  "version": "0.1.0",
  "description": "Agent-agnostic skills that distill meeting transcripts into artifacts (insight cards, articles, micro-podcasts).",
  "type": "module",
  "private": true,
  "scripts": {
    "artifact:inflate": "bash scripts/artifact-inflate.sh",
    "artifact:dev": "bash scripts/artifact-dev.sh",
    "artifact:dev:https": "bash scripts/artifact-dev-https.sh",
    "artifact:frontend": "bash scripts/artifact-feed-dev.sh",
    "artifact:frontend:check": "bash scripts/artifact-feed-check.sh",
    "artifact:backend": "bash scripts/artifact-distillery-backend.sh",
    "artifact:agent:dev:https": "bunx portless run --name agent.feed bash scripts/artifact-agent-dev-https.sh",
    "artifact:agent:dev:raw": "bash scripts/artifact-agent-dev-https.sh",
    "artifact:backend:smoke": "bash scripts/artifact-backend-smoke.sh",
    "artifact:test": "bash scripts/artifact-check.sh",
    "smithers:doctor": "bunx smithers-orchestrator workflow doctor",
    "smithers:list": "bunx smithers-orchestrator workflow list",
    "smithers:ps": "bunx smithers-orchestrator ps --all",
    "smithers:why": "bunx smithers-orchestrator why",
    "smithers:cancel": "bunx smithers-orchestrator cancel",
    "smithers:dev-mode": "bunx smithers-orchestrator workflow run feed-dev-mode",
    "smithers:agent-run": "bunx smithers-orchestrator workflow run agent-run",
    "smithers:agent-run:staged": "bunx smithers-orchestrator workflow run agent-run-staged",
    "smithers:artifact-types": "bunx smithers-orchestrator workflow run artifact-type-smoke",
    "smithers:composition": "bunx smithers-orchestrator workflow run feed-composition-smoke",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}
