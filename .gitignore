# dependencies
node_modules/

# generated artifacts (skill output)
artifacts/
out/

# quarantined artifacts (skill output flagged for review — contains real
# meeting content: names, unannounced numbers, the very leaks the comms
# skills exist to catch). Same stance as artifacts/. Anchored to repo root.
/.quarantine/

# feedback event log (personal data, like artifacts/) — anchored to the
# repo root so a future source dir named feedback/ isn't silently ignored
/feedback/

# corpus index + surfaced-topics ledger + run log (derived AND contains
# meeting content: entities, quote context, speaker names) — same treatment
# as artifacts/ and feedback/. Anchored to the repo root.
/index/

# secrets
.env
.env.*
!.env.example
*.local

# launchd per-deploy env (machine-specific tool paths + the OpenKey allowlist +
# transcript dirs) and runtime logs — never committed; .example files document
# the shape. Same stance as .env.
/harness/ops/launchd/feedrun.env
/harness/ops/launchd/server.env
/harness/ops/launchd/logs/

# verification screenshots (regenerated per run)
/harness/feed/screenshots/

# os / editor / harness scratch
.DS_Store
drafts/
artifacts-v2/
.claude/

# tc delegation/host hand-off artifacts (runtime, identity-bearing) + Listen corpus
listen-read-request.json
listen-read-grant.json
host-request.json
delegation-request.json
delegation-grant.json
/corpus/
