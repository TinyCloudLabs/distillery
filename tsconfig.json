{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["bun"]
  },
  "include": [
    "skills/**/*.ts",
    "harness/feed-run/**/*.ts",
    "harness/index-corpus/**/*.ts",
    "harness/query-corpus/**/*.ts",
    "harness/distill-preferences/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["harness/feed"]
}
